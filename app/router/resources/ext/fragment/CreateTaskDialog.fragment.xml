<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        title="{i18n>createDialogTitle}"
        contentWidth="500px"
        draggable="true"
        resizable="true">

        <content>
            <VBox class="sapUiSmallMargin">
                <Label text="{i18n>fieldTitle}" />
                <Input value="{createTask>/title}" required="true" />

                <Label text="{i18n>fieldDescription}" class="sapUiSmallMarginTop" />
                <TextArea value="{createTask>/description}" rows="5" required="true" />

                <Label text="{i18n>fieldStatus}" class="sapUiSmallMarginTop" />
                <Select selectedKey="{createTask>/status}">
                    <items>
                        <core:Item key="TO-DO" text="{i18n>statusTodo}" />
                        <core:Item key="DOING" text="{i18n>statusDoing}" />
                        <core:Item key="DONE" text="{i18n>statusDone}" />
                    </items>
                </Select>

                <Label text="{i18n>fieldPriority}" class="sapUiSmallMarginTop" />
                <Select selectedKey="{createTask>/priority}">
                    <items>
                        <core:Item key="HIGH" text="{i18n>priorityHigh}" />
                        <core:Item key="MEDIUM" text="{i18n>priorityMedium}" />
                        <core:Item key="LOW" text="{i18n>priorityLow}" />
                    </items>
                </Select>

                <Label text="{i18n>fieldResponsible}" class="sapUiSmallMarginTop" />
                <Input value="{createTask>/responsible}" required="true" />
            </VBox>
        </content>

        <beginButton>
            <Button
                text="{i18n>saveButtonText}"
                type="Emphasized"
                press=".onSaveCreateDialog" />
        </beginButton>

        <endButton>
            <Button
                text="{i18n>cancelButtonText}"
                press=".onCancelCreateDialog" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>